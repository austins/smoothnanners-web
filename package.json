{
    "name": "smoothnanners-web",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "export": "npm run build && next export",
        "lint": "next lint . --ext .js --ext .ts --ext .jsx --ext .tsx",
        "format": "npx prettier --write . && npm run lint -- --fix",
        "analyze": "cross-env ANALYZE=true npm run build"
    },
    "engines": {
        "node": ">=16.13.1"
    },
    "dependencies": {
        "bootstrap": "^5.1.3",
        "bootswatch": "^5.1.3",
        "http-status-codes": "^2.2.0",
        "next": "^12.2.2",
        "next-compose-plugins": "^2.2.1",
        "phosphor-react": "^1.4.1",
        "react": "^18.2.0",
        "react-bootstrap": "^2.4.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^12.2.2",
        "@types/node": "^18.0.4",
        "@types/react": "^18.0.15",
        "@typescript-eslint/eslint-plugin": "^5.30.6",
        "@typescript-eslint/parser": "^5.30.6",
        "cross-env": "^7.0.3",
        "eslint": "^8.19.0",
        "eslint-config-next": "^12.2.2",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-unused-imports": "^2.0.0",
        "prettier": "^2.7.1",
        "sass": "^1.53.0",
        "typescript": "^4.7.4"
    }
}
