{
    "name": "smoothnanners-web",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "astro dev",
        "start": "astro dev",
        "build": "npm run lint && astro build",
        "preview": "astro preview",
        "astro": "astro",
        "lint": "tsc --noEmit && astro check && eslint . --ext .js --ext .ts --ext .jsx --ext .tsx",
        "format": "npm run lint -- --fix && prettier --write --plugin-search-dir=. ."
    },
    "engines": {
        "node": ">=16.17.0"
    },
    "dependencies": {
        "@astrojs/image": "^0.7.1",
        "@astrojs/react": "^1.1.4",
        "@fontsource/kalam": "^4.5.9",
        "@fontsource/open-sans": "^4.5.11",
        "@popperjs/core": "^2.11.6",
        "astro": "^1.2.8",
        "bootstrap": "^5.2.1",
        "bootswatch": "^5.2.1",
        "phosphor-react": "^1.4.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.0.20",
        "@types/react-dom": "^18.0.6",
        "@typescript-eslint/eslint-plugin": "^5.38.0",
        "@typescript-eslint/parser": "^5.38.0",
        "eslint": "^8.23.1",
        "eslint-plugin-astro": "^0.19.0",
        "eslint-plugin-unused-imports": "^2.0.0",
        "prettier": "^2.7.1",
        "prettier-plugin-astro": "^0.5.4",
        "sass": "^1.54.9"
    }
}
