{
    "name": "smoothnanners-web",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "astro dev",
        "build": "npm run lint && astro build",
        "preview": "astro preview",
        "lint": "tsc --noEmit && astro check && npm run lint:eslint",
        "lint:eslint": "eslint . --ext .js --ext .ts --ext .jsx --ext .tsx",
        "format": "npm run lint:eslint -- --fix && prettier --write --plugin-search-dir=. ."
    },
    "engines": {
        "node": ">=18.12.1"
    },
    "dependencies": {
        "@astrojs/image": "^0.12.1",
        "@astrojs/react": "^1.2.2",
        "astro": "^1.8.0",
        "phosphor-react": "^1.4.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "sharp": "^0.31.3"
    },
    "devDependencies": {
        "@types/node": "^18.11.18",
        "@types/react": "^18.0.26",
        "@types/react-dom": "^18.0.10",
        "@typescript-eslint/eslint-plugin": "^5.47.1",
        "@typescript-eslint/parser": "^5.47.1",
        "eslint": "^8.30.0",
        "eslint-plugin-astro": "^0.21.1",
        "eslint-plugin-unused-imports": "^2.0.0",
        "prettier": "^2.8.1",
        "prettier-plugin-astro": "^0.7.0"
    }
}
