{
    "name": "smoothnanners-web",
    "private": true,
    "devEngines": {
        "runtime": {
            "name": "node",
            "onFail": "error"
        },
        "packageManager": {
            "name": "pnpm",
            "onFail": "error"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "vite --mode ssr",
        "preview": "qwik build preview && vite preview --open",
        "build": "qwik build",
        "build.client": "vite build",
        "build.preview": "vite build --ssr ./src/entry.preview.ts",
        "build.server": "qwik check-client ./src ./dist && vite build -c ./adapters/static/vite.config.ts",
        "build.types": "tsc",
        "lint": "tsc && oxfmt --check && oxlint",
        "format": "oxfmt && oxlint --fix",
        "qwik": "qwik"
    },
    "devDependencies": {
        "@builder.io/qwik": "1.19.2",
        "@builder.io/qwik-city": "1.19.2",
        "@iconify-json/tabler": "1.2.35",
        "@iconify/tailwind4": "1.2.3",
        "@tailwindcss/vite": "4.3.0",
        "@types/node": "25.8.0",
        "eslint-plugin-better-tailwindcss": "4.5.0",
        "ignore": "7.0.5",
        "oxfmt": "0.50.0",
        "oxlint": "1.65.0",
        "oxlint-plugin-qwik": "0.0.8",
        "tailwindcss": "4.3.0",
        "typescript": "6.0.3",
        "undici": "8.3.0",
        "vite": "7.3.3"
    }
}
