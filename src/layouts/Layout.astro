---
export interface Props {
    title?: string;
}

const siteName = "SmoothNanners";

const title = Astro.props.title ? `${Astro.props.title} – ${siteName}` : siteName;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <title>{title}</title>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Kalam:wght@300&family=Open+Sans:wght@300&display=swap"
            rel="stylesheet"
        />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.2/dist/vapor/bootstrap.min.css" />
        <slot name="head" />
    </head>

    <body>
        <div id="main" class="container d-flex align-items-center py-3">
            <div class="w-100">
                <header>
                    <h1 id="header-text" class="mb-2 text-white">
                        {siteName}
                    </h1>
                </header>

                <main><slot /></main>
            </div>
        </div>

        <style is:global>
            body {
                background-repeat: no-repeat;
                background-color: #0c1f4c;
                background-image: linear-gradient(#17082e 0%, #1a0933 4%, #1a0933 12%, #0c1f4c 100%);

                font-family: "Open Sans", Lato, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
                    Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
            }

            #header-text {
                font-family: "Kalam", Lato, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
                    Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";

                font-size: 3.5rem;
                text-shadow: 0 0 2px rgba(255, 255, 255, 0.8), 0 0 4px rgba(255, 255, 255, 0.3),
                    0 0 1rem rgba(255, 255, 255, 0.2), 0 0 4rem rgba(68, 217, 232, 0.1);
            }

            #main {
                max-width: 600px;
                min-height: 100vh;
            }

            @media only screen and (max-width: 575px) {
                #header-text {
                    font-size: 9.7vw !important;
                }
            }
        </style>
    </body>
</html>
